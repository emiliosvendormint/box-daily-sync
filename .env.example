# PostgreSQL connection URL for the local DMS3 database
APP_DATABASE_URL=postgresql://user:password@localhost:5433/dms3

# Box API credentials (Client Credentials Grant)
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_SUBJECT_ID=

# GCS settings
GCS_BUCKET_NAME=
GOOGLE_CREDS_SR=
GOOGLE_CREDS=

# Optional tuning
BOX_API_DELAY=0.2
BOX_BATCH_SIZE=500
BOX_MAX_RETRIES=4
